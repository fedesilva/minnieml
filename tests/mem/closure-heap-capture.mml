
fn makeGreeter(~name: String): Unit -> Unit =
  { println ("Hello, " ++ name); };
;

fn loop(n: Int): Unit =
  if n > 0 then
    let string = "User" ++ (int_to_str n);
    let greet = makeGreeter string ;    
    // println string;
    greet ();
    loop (n - 1);
  ;
;

pub fn main(): Unit =
  loop 100000;
;
