// Nested lambdas with captures.

pub fn main() =
  println ("What's your name?");
  let name = 1;

  let f = {
    println ("Type a number, " ++ (int_to_str name));
    let n = str_to_int (readline());

    let g = {
      println ("Number is: " ++ (int_to_str n) ++ ", " ++ (int_to_str name));
    }: Unit;

    g();
  };
  f();
;
